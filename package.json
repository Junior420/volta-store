{
  "name": "volta-store-cloudflare",
  "version": "1.0.0",
  "description": "Volta Store backend on Cloudflare Pages — Hono + D1 + R2 + KV",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev .",
    "db:migrate:local": "wrangler d1 execute volta --local --file=migrations/schema.sql",
    "db:seed:local": "wrangler d1 execute volta --local --file=migrations/seed.sql",
    "db:migrate:remote": "wrangler d1 execute volta --remote --file=migrations/schema.sql",
    "db:seed:remote": "wrangler d1 execute volta --remote --file=migrations/seed.sql",
    "deploy": "wrangler pages deploy ."
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
